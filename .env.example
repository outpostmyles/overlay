# Overlay configuration. Copy this file to .env and fill in what you want.
# Everything here is OPTIONAL: the app runs fully on free, no-key sources
# (Polymarket · Kalshi · PrizePicks · ESPN) with none of these set.

# The Odds API - sportsbook moneyline + total-corner lines.
# Free tier is 500 credits/month. https://the-odds-api.com
ODDS_API_KEY=

# Anthropic - AI match research + on-demand per-prop reads (manual trigger, disk-cached).
# https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# API-Football - per-player and per-team match stats used to auto-settle props/corners.
# Free tier is 100 requests/day. https://www.api-football.com
APIFOOTBALL_KEY=

# Bankroll and unit sizing (1 unit = UNIT_PCT of bankroll).
BANKROLL=1000
UNIT_PCT=0.01
